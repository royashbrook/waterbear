#!/usr/bin/env bash
# waterbear , keep a `claude --remote-control` session alive on macOS.
#
# named for the tardigrade: the animal that suspends its life under stress and revives when
# conditions return. this is the same trick for a Claude Code session. remote-control mode keeps
# ONE session reachable from your phone, the desktop app, and claude.ai at once; this wraps it in
# tmux (a real pty plus a local `attach` surface) and a launchd LaunchAgent (starts it at login,
# respawns it if it dies), so the session is durable instead of dying with the terminal that
# launched it. with CLAUDE_RC_RESUME=1 a respawn RESUMES the prior conversation from its on-disk
# transcript, so the agent comes back as itself, mid-thought, not a blank slate.
#
# PREREQ: install the claude CLI and run `claude` once to log in. this reuses your
# existing login, it does not handle auth. tmux is required (brew install tmux).
#
# install:
#   curl -fsSL https://raw.githubusercontent.com/royashbrook/waterbear/main/scripts/waterbear-install | bash
#   # or configure the session:
#   CLAUDE_RC_NAME=work CLAUDE_RC_DIR=~/code \
#     curl -fsSL https://raw.githubusercontent.com/royashbrook/waterbear/main/scripts/waterbear-install | bash
#
# env:
#   CLAUDE_RC_NAME   session / tmux name           (default: claude)
#                    internal id: names the tmux session, the launchd label, and the id file.
#                    keep it short + space-free (it goes in a launchd label + `tmux -t`).
#   CLAUDE_RC_TITLE  display title in the session list (phone/desktop/claude.ai). default: NAME.
#                    decoupled from NAME so it can be pretty (e.g. "Roy - Theaetetus") while the
#                    internal name stays short. cosmetic , resume keys on the id, not the title.
#   CLAUDE_RC_DIR    working dir for the session   (default: $HOME)
#   CLAUDE_RC_WAKE   optional first prompt to auto-run on a FRESH (re)spawn (default: none).
#                    a respawn is a fresh session with no keyboard behind it, so if you set
#                    this, the guard types it into the new session once it's ready , use it to
#                    re-establish context on restart (e.g. a project/role bootstrap prompt).
#   CLAUDE_RC_RESUME       "1" = on respawn, RESUME the last conversation by id instead of a
#                          fresh one (true always-on). needs the session-id capture hook that
#                          records the live id to ~/.claude/rc-session-<name> on each start.
#                          the transcript on disk survives a crash, so resume restores it whole.
#   CLAUDE_RC_RESUME_WAKE  optional prompt typed AFTER a resume (default: none). resume restores
#                          identity+context but not session-armed rails (a doorbell/monitor dies
#                          with the process), so use this to re-arm them (e.g. a short re-init cue).
#
# after install:
#   attach:  tmux attach -t <name>     (also reachable on your phone / desktop app / claude.ai)
#   logs:    /tmp/<label>.log  /tmp/<label>.err
#   stop:    launchctl bootout gui/$(id -u)/<label>
#
# note: by default this keeps a LIVE session reachable and respawns a FRESH one if it dies.
# with CLAUDE_RC_RESUME=1 it instead resumes the prior conversation from its on-disk transcript,
# so the respawn picks up where it left off. a resume that fails once (stale id) falls back to a
# fresh start on the next respawn (the guard consumes the id file so it can't crashloop on it).
set -euo pipefail

NAME="${CLAUDE_RC_NAME:-claude}"
TITLE="${CLAUDE_RC_TITLE:-$NAME}"
WORKDIR="${CLAUDE_RC_DIR:-$HOME}"
WAKE="${CLAUDE_RC_WAKE:-}"
RESUME="${CLAUDE_RC_RESUME:-}"
RESUME_WAKE="${CLAUDE_RC_RESUME_WAKE:-}"
DOORBELL="${CLAUDE_RC_DOORBELL:-}"
USER_ID="$(id -u)"
SHORTUSER="$(id -un | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9')"
LABEL="com.${SHORTUSER}.claude-rc.${NAME}"
BIN_DIR="$HOME/.local/bin"
GUARD="$BIN_DIR/claude-rc-keepalive"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"

# --- locate deps now: launchd runs with a bare PATH, so bake the real dirs into the plist ---
CLAUDE_BIN="$(command -v claude || true)"
TMUX_BIN="$(command -v tmux || true)"
[ -n "$CLAUDE_BIN" ] || { echo "waterbear: claude CLI not found on PATH. install it, then run 'claude' once to log in." >&2; exit 1; }
[ -n "$TMUX_BIN" ]   || { echo "waterbear: tmux not found. run 'brew install tmux' then re-run." >&2; exit 1; }
RC_PATH="$(dirname "$CLAUDE_BIN"):$(dirname "$TMUX_BIN"):/usr/bin:/bin:/usr/sbin:/sbin"

mkdir -p "$BIN_DIR" "$HOME/Library/LaunchAgents"

# --- the keepalive guard: ensure the session is alive, block while it lives, exit when it
#     dies so launchd KeepAlive respawns us (which recreates it). ---
cat > "$GUARD" <<'GUARD_EOF'
#!/usr/bin/env bash
set -euo pipefail
NAME="${CLAUDE_RC_NAME:-claude}"
TITLE="${CLAUDE_RC_TITLE:-$NAME}"
WORKDIR="${CLAUDE_RC_DIR:-$HOME}"
WAKE="${CLAUDE_RC_WAKE:-}"
RESUME="${CLAUDE_RC_RESUME:-}"
RESUME_WAKE="${CLAUDE_RC_RESUME_WAKE:-}"
SESSION_FILE="${CLAUDE_RC_SESSION_FILE:-$HOME/.claude/rc-session-$NAME}"
DOORBELL="${CLAUDE_RC_DOORBELL:-}"   # optional: a signal file the GUARD watches; a new line => wake the session
command -v tmux   >/dev/null 2>&1 || exit 78
command -v claude >/dev/null 2>&1 || exit 78

# crashloop detection: if the session GENUINELY dies + respawns fast (a bad resume id, corrupt state,
# disk full, etc.), stop hammering, notify the human once, and back off. NOTE: an expired login does
# NOT trigger this , that leaves the session ALIVE showing an auth error (visible via remote-control),
# so it announces itself and a human clears it with claude + /login.
mkdir -p "$HOME/.claude"
LAUNCH_LOG="$HOME/.claude/rc-launches-$NAME"; STUCK_FLAG="$HOME/.claude/rc-stuck-$NAME"
NOW=$(date +%s)
printf '%s\n' "$NOW" >> "$LAUNCH_LOG"
RECENT=$(awk -v n="$NOW" '($1+0) > n-120' "$LAUNCH_LOG" 2>/dev/null || true)
printf '%s\n' "$RECENT" > "$LAUNCH_LOG"
if [ "$(printf '%s\n' "$RECENT" | grep -c .)" -ge 4 ]; then
  if [ ! -f "$STUCK_FLAG" ]; then
    : > "$STUCK_FLAG"
    command -v osascript >/dev/null 2>&1 && osascript -e "display notification \"$NAME keeps dying, likely an expired login. run: claude then /login at the machine.\" with title \"waterbear: $NAME needs a re-login\"" >/dev/null 2>&1 || true
  fi
  sleep 300   # back off so launchd doesn't respawn us in a tight loop until the human reauths
  exit 0
fi
rm -f "$STUCK_FLAG" 2>/dev/null || true   # a healthy start clears the stuck flag

if ! tmux has-session -t "$NAME" 2>/dev/null; then
  # resume the prior conversation by id if configured AND we have a captured id; else fresh.
  # tmux session name is $NAME (short); the remote-control display TITLE is separate (may have spaces).
  SID=""
  if [ "$RESUME" = "1" ] && [ -s "$SESSION_FILE" ]; then
    SID="$(head -n1 "$SESSION_FILE" | tr -d '[:space:]')"
  fi
  # -e "CLAUDE_RC_NAME=$NAME" is LOAD-BEARING when more than one waterbear body runs on the same
  # machine. they share one tmux server; the FIRST body to boot seeds the server's global
  # environment with its own CLAUDE_RC_NAME, and every later `new-session` inherits it, so all
  # panes would otherwise see the first body's name. the SessionStart capture hook keys the
  # resume-id file on CLAUDE_RC_NAME, so without this every body writes rc-session-<first>, the
  # others' files never update, and the next boot resumes crossed ids (body B comes up as body A).
  # setting it per-session overrides the poisoned server env. (single-body users never hit this.)
  if [ -n "$SID" ]; then
    # consume the id first: if this resume is what's crashing, the next respawn finds no id
    # and falls back to a fresh start instead of looping on a bad resume. a SUCCESSFUL resume
    # re-runs SessionStart, and the capture hook rewrites the id file with the live session.
    mv -f "$SESSION_FILE" "$SESSION_FILE.consumed" 2>/dev/null || true
    tmux new-session -d -s "$NAME" -e "CLAUDE_RC_NAME=$NAME" -c "$WORKDIR" "claude --remote-control \"$TITLE\" --resume $SID"
    NUDGE="$RESUME_WAKE"
  else
    tmux new-session -d -s "$NAME" -e "CLAUDE_RC_NAME=$NAME" -c "$WORKDIR" "claude --remote-control \"$TITLE\""
    NUDGE="$WAKE"
  fi
  # launchd has no hands. if a prompt is set, type it into the session once its UI has settled
  # (drawn the input box), so a respawn comes up as itself, not a blank assistant. a positional
  # prompt does NOT auto-run in interactive mode and under --remote-control is read as a session
  # title, so send-keys is the only lever here.
  if [ -n "$NUDGE" ]; then
    prev=""; stable=0
    for _ in $(seq 1 45); do
      cur="$(tmux capture-pane -pt "$NAME" 2>/dev/null || true)"
      if [ -n "$cur" ] && [ "$cur" = "$prev" ]; then
        stable=$((stable + 1))
        if [ "$stable" -ge 2 ]; then break; fi
      else
        stable=0
      fi
      prev="$cur"
      sleep 1
    done
    sleep 2
    # a LARGE session resumes behind an interactive "Resume from summary / Resume full session /
    # Don't ask me again" menu. a blind wake keystroke can't navigate it (it stalls at the modal or
    # picks an option by accident). detect it and choose the recommended SUMMARY option, which also
    # sheds the bloat. option 1 is pre-highlighted, so a single Enter selects it.
    cur="$(tmux capture-pane -pt "$NAME" 2>/dev/null || true)"
    case "$cur" in
      *"Resume from summary"*)
        tmux send-keys -t "$NAME" Enter 2>/dev/null || true
        sleep 3
        ;;
    esac
    # CLEAR the input line before waking. if the prior (stalled) session left text typed in the input
    # box, the wake's Enter would submit that text concatenated with the wake, so a stale command
    # could fire on respawn. C-u kills the line so the wake lands in an empty prompt. (verified: C-u
    # alone clears cleanly; Escape/Ctrl-C were rejected, Escape is readline's meta-prefix and mangles
    # the following keystrokes, and a double Ctrl-C can exit the session.)
    # NOTE: this covers stale text in the INPUT LINE. It does NOT cover already-QUEUED messages (text
    # submitted-to-queue while a prior turn ran, which auto-send on resume). That is the harder case,
    # tracked separately, C-u cannot reach the queue and no clean guard-only flush exists yet.
    tmux send-keys -t "$NAME" C-u 2>/dev/null || true
    sleep 1
    tmux send-keys -t "$NAME" -l "$NUDGE"
    sleep 1
    tmux send-keys -t "$NAME" Enter
    sleep 4
    tmux send-keys -t "$NAME" Enter   # race-defeat: an empty Enter is a no-op if already submitted
  fi
fi
# doorbell (optional): the GUARD, not the session, watches the signal file. so it survives a
# client patch that would kill a session-owned watcher, and the session burns ZERO tokens sitting
# on a tail. on a new line it send-keys a wake into the live session. this is the "watch in the
# durable layer, only touch the session on a real event" model. start at EOF so old rings are not
# replayed. (idle-detection before the send-keys is a known TODO: a ring mid-generation queues.)
db_off=0
if [ -n "$DOORBELL" ] && [ -f "$DOORBELL" ]; then
  db_off=$(wc -c < "$DOORBELL" 2>/dev/null | tr -d ' ' || echo 0)
fi
while tmux has-session -t "$NAME" 2>/dev/null; do
  if [ -n "$DOORBELL" ] && [ -f "$DOORBELL" ]; then
    cur=$(wc -c < "$DOORBELL" 2>/dev/null | tr -d ' ' || echo 0)
    cur=${cur:-0}; db_off=${db_off:-0}
    if [ "$cur" -lt "$db_off" ]; then db_off=0; fi          # file truncated / rotated: reset
    if [ "$cur" -gt "$db_off" ]; then
      ring=$(tail -c "+$((db_off + 1))" "$DOORBELL" 2>/dev/null | tr '\n' ' ' | cut -c1-400 || true)
      db_off=$cur
      if [ -n "$ring" ]; then
        tmux send-keys -t "$NAME" -l "[doorbell] sibling ring, check the bus: $ring" 2>/dev/null || true
        sleep 1; tmux send-keys -t "$NAME" Enter 2>/dev/null || true
      fi
    fi
  fi
  sleep 10
done
exit 0
GUARD_EOF
chmod +x "$GUARD"

# --- the LaunchAgent ---
cat > "$PLIST" <<PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>            <string>${LABEL}</string>
  <key>ProgramArguments</key> <array><string>${GUARD}</string></array>
  <key>RunAtLoad</key>        <true/>
  <key>KeepAlive</key>        <true/>
  <key>ThrottleInterval</key> <integer>10</integer>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>           <string>${RC_PATH}</string>
    <key>CLAUDE_RC_NAME</key>        <string>${NAME}</string>
    <key>CLAUDE_RC_TITLE</key>       <string>${TITLE}</string>
    <key>CLAUDE_RC_DIR</key>         <string>${WORKDIR}</string>
    <key>CLAUDE_RC_WAKE</key>        <string>${WAKE}</string>
    <key>CLAUDE_RC_RESUME</key>      <string>${RESUME}</string>
    <key>CLAUDE_RC_RESUME_WAKE</key> <string>${RESUME_WAKE}</string>
    <key>CLAUDE_RC_DOORBELL</key>    <string>${DOORBELL}</string>
    <key>HOME</key>                  <string>${HOME}</string>
  </dict>
  <key>StandardOutPath</key>  <string>/tmp/${LABEL}.log</string>
  <key>StandardErrorPath</key><string>/tmp/${LABEL}.err</string>
</dict>
</plist>
PLIST_EOF

# --- (re)bootstrap into launchd (idempotent) ---
launchctl bootout "gui/${USER_ID}/${LABEL}" 2>/dev/null || true
if ! launchctl bootstrap "gui/${USER_ID}" "$PLIST" 2>/dev/null; then
  launchctl load -w "$PLIST"
fi
launchctl enable "gui/${USER_ID}/${LABEL}" 2>/dev/null || true

echo "waterbear: installed + started."
echo "  session name : ${NAME}"
echo "  working dir  : ${WORKDIR}"
echo "  attach       : tmux attach -t ${NAME}   (also on your phone / desktop app / claude.ai)"
echo "  logs         : /tmp/${LABEL}.log   /tmp/${LABEL}.err"
echo "  stop         : launchctl bootout gui/${USER_ID}/${LABEL}"
echo
echo "if a session was already running under that name, it was adopted (not restarted)."
